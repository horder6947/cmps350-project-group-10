generator client {
  provider = "prisma-client-js"
  output   = "client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id       String @id @default(cuid(2))
  username String
  email    String @unique
  password String // plaintext password for easier testing and demo

  bio          String   @default("No bio")
  date_created DateTime @default(now())

  following Follows[] @relation("Following")
  followers Follows[] @relation("Followers")
  posts     Post[]
  likes     Like[]
  comments  Comment[]
}

model Follows {
  follower_id String // FK
  followee_id String // FK

  followee User @relation("Followers", references: [id], fields: [followee_id], onDelete: Cascade)
  follower User @relation("Following", references: [id], fields: [follower_id], onDelete: Cascade)

  @@id([followee_id, follower_id])
}

model Post {
  id String @id @default(cuid(2))

  author_id String // FK
  author    User   @relation(fields: [author_id], references: [id], onDelete: Cascade)

  post_content String
  date_created DateTime @default(now())

  likes    Like[]
  comments Comment[]
}

model Like {
  post_id  String // FK
  liker_id String // FK

  post  Post @relation(references: [id], fields: [post_id], onDelete: Cascade)
  liker User @relation(references: [id], fields: [liker_id], onDelete: Cascade)

  @@id([post_id, liker_id])
}

model Comment {
  id           String   @id @default(cuid(2))
  author_id    String // FK
  post_id      String // FK
  date_created DateTime @default(now())
  comment      String

  author User @relation(references: [id], fields: [author_id], onDelete: Cascade)
  post   Post @relation(references: [id], fields: [post_id], onDelete: Cascade)
}
